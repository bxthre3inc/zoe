{
  "name": "zoe-project",
  "version": "0.1.0-alpha",
  "description": "The most capable, human-like digital assistant — open source and living",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check .",
    "lint:fix": "biome check . --apply",
    "format": "biome format . --write"
  },
  "keywords": [
    "ai",
    "assistant",
    "agent",
    "living-ai",
    "memory",
    "orchestration",
    "open-source",
    "bxthre3",
    "farmsense",
    "zo"
  ],
  "author": "brodiblanco <brodiblanco@zo.computer>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bxthre3inc/zoe.git"
  },
  "bugs": {
    "url": "https://github.com/bxthre3inc/zoe/issues"
  },
  "homepage": "https://github.com/bxthre3inc/zoe#readme",
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "hono": "^3.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.5.0",
    "@types/bun": "latest",
    "typescript": "^5.3.0"
  }
}
