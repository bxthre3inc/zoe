# --- VPC ENVIRONMENT TEMPLATE ---
# Copy this file to .env and fill in the secrets.

# --- App Server Settings ---
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
DB_PATH=vpc.db
# Generate using: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-here
# Domain for WebSocket connections (e.g., vpc.zo.computer)
WSS_DOMAIN=localhost:3001
# CORS: Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://vpc.zo.computer

# --- AI & Personalization (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3

# --- Payment Gateways ---
# Stripe for Card/ACH
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# BTC/Crypto (BitPay or Coinbase Commerce)
CRYPTO_PROVIDER_API_KEY=your_api_key
BTC_MASTER_ADDRESS=bc1q_placeholder_address_here

# Cash App
CASHAPP_CASHTAG=$ValleyPlayersClub

# --- Compliance & KYC (Persona / Jumio) ---
PERSONA_API_KEY=your_persona_key
PERSONA_TEMPLATE_ID=your_template_id
MAXMIND_ACCOUNT_ID=your_maxmind_account_id
MAXMIND_LICENSE_KEY=your_maxmind_key

# --- Zo Deployment (GitHub Secrets) ---
# You MUST set these in your GitHub Repo Secrets for CI/CD to work.
ZO_HOST=your_server_ip
ZO_USER=your_ssh_username
ZO_SSH_KEY=your_ssh_private_key
